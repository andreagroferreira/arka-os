      {
        "expect": "delegate",
        "tool": "WebSearch"
      },
      {
        "expect": "delegate",
        "tool": "WebFetch"
      },
      {
        "expect": "delegate",
        "tool": "mcp__context7__query-docs"
      },
      {
        "expect": "delegate",
        "tool": "mcp__firecrawl__firecrawl_scrape"
      },
      {
        "expect": "delegate",
        "tool": "Write"
      },
      {
        "expect": "delegate",
        "tool": "Edit"
      },
      {
        "expect": "delegate",
        "tool": "MultiEdit"
      },
      {
        "expect": "delegate",
        "tool": "NotebookEdit"
      },
      {
        "expect": "delegate",
        "tool": "Task"
      },
      {
        "expect": "delegate",
        "tool": "Skill"
      }
