    "name": "WizardingCode",
    "url": "https://wizardingcode.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreagroferreira/arka-os.git"
  },
  "homepage": "https://arkaos.dev",
  "bugs": {
    "url": "https://github.com/andreagroferreira/arka-os/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "installer/",
    "core/",
    "departments/",
    "harness/",
    "mcps/",
    "scripts/",
    "config/",
    "bin/arka",
    "bin/arka-claude",
    "bin/arka-claude.cmd",
    "bin/arka-claude.ps1",
    "bin/arka-doctor",
    "bin/arka-providers",
    "bin/arka-py",
