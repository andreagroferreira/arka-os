    "bin/scheduler-daemon.py",
    "arka/",
    "knowledge/",
    "dashboard/app/",
    "dashboard/nuxt.config.ts",
    "dashboard/package.json",
    "dashboard/tsconfig.json",
    "dashboard/pnpm-workspace.yaml",
    "pyproject.toml",
    "VERSION",
    "CONSTITUTION.md",
    "THE-ARKAOS-GUIDE.md",
    "README.md",
    "LICENSE",
    "!**/__pycache__/",
    "!**/*.pyc",
    "!**/.DS_Store",
    "!departments/dev/skills/diagram/vendor/test/"
